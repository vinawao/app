{
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    {
      "src": "/(.*)\\.(html|css|js|gif|jpg|png|svg|ico|txt|json|m3u|m3u8)$",
      "dest": "/api/$1.$2"
    },
    {
      "src": "/(.*)",
      "dest": "/api/$1"
    },
    { "src": "/playlist", "dest": "/api/playlist.js" }
  ]
}



