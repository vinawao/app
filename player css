/* ===== SHAKA CONTROLS FADE OUT ===== */

/* Target the controls container */
.shaka-controls-container {
  /* Override the default transition time for opacity changes */
  transition: opacity 5s ease-in-out !important;
}

/* Ensure the hidden state (opacity: 0) also respects the transition */
.shaka-controls-container.shaka-controls-hidden {
  opacity: 0 !important;
  /* Add pointer-events: none; to prevent the hidden controls from
     interfering with mouse events on the video element if needed */
  pointer-events: none;
}


