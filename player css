.blink {
    /* Define the animation properties */
    animation-name: blinkingText;
    animation-duration: 1.8s; /* Control the speed */
    animation-iteration-count: infinite; /* Make it blink forever */
    animation-fill-mode: both;
}

/* Define the keyframes for the animation */
@keyframes blinkingText {
    0% {
        opacity: 0; /* Text is transparent at the start */
    }
    50% {
        opacity: 1; /* Text is fully visible at 50% through the duration */
    }
    100% {
        opacity: 0; /* Text is transparent again at the end */
    }
}


