  /* animation: fadeOut 3s 4s forwards; */
}

@keyframes fadeOut {
  0% {
    opacity: 1;
  }
  100% {
    opacity: 0;
    /* visibility: hidden; /* Tambahkan ini agar tidak bisa diklik saat transparan */
    display: none; /* Opsional: Benar-benar menghilangkan elemen dari layout */
  }
}




