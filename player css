#msg {} 

.message { /*visibility: hidden; display: none;*/ position: absolute; top: 60px;
left: 50%; z-index: 9999; 
transform: translate(-50%, -50%);
  word-wrap: break-word; overflow-wrap: break-word; 
  /* Pengaturan Awal */
  opacity: 1; text-align: center;
